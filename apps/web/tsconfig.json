{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2017",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "module": "esnext",
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],

  "exclude": ["node_modules"]
}
